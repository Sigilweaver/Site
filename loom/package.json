{
  "name": "sigilweaver-site-loom",
  "version": "1.0.0",
  "type": "module",
  "description": "Loom marketing site — served at sigilweaver.app/loom",
  "engines": {
    "node": ">=18.0"
  },
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemaps.mjs",
    "build": "bun run sitemap && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-favicon": "node public/icons/generate-favicon.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prismjs": "^1.26.5",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.32",
    "sharp": "^0.32.6",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.2",
    "vite": "^5.0.6",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "data-engineering",
    "visualization",
    "pipeline",
    "open-source"
  ],
  "author": "Sigilweaver Loom Team",
  "license": "MIT",
  "dependencies": {
    "lucide": "^0.556.0",
    "prismjs": "^1.30.0"
  }
}